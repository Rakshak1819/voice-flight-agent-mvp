# Optional: enables OpenAI-powered slot extraction + natural responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SPEECH_ENABLED=true
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
STT_LANGUAGE=en
STT_PROMPT=
STT_MIN_RECORD_SECONDS=1.2
STT_DEBUG=false
# Optional microphone selector (index or partial device name from '/devices')
AUDIO_INPUT_DEVICE=

# Optional: local offline speech-to-text (Vosk)
# Example (Windows): C:\models\vosk-model-small-en-us-0.15
VOSK_MODEL_PATH=

# Optional: local offline speech synthesis (Piper)
# Example (Windows): C:\tools\piper\piper.exe
PIPER_EXECUTABLE=
# Example: C:\voices\en_US-lessac-medium.onnx
PIPER_VOICE_MODEL=

# Feature toggles
STT_ENABLED=true
TTS_ENABLED=true
